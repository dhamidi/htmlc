FROM golang:1.25-alpine AS builder
WORKDIR /build
COPY . .
WORKDIR /build/examples/shape-canvas
RUN go build -o /build/shape-canvas .

FROM alpine:3.19
WORKDIR /app
COPY --from=builder /build/shape-canvas .
COPY --from=builder /build/examples/shape-canvas/components ./components
COPY --from=builder /build/examples/shape-canvas/pages ./pages
ENV PORT=9000
ENV HOST=0.0.0.0
EXPOSE 9000
CMD ["./shape-canvas"]
